# GraceTracks environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: Supabase project credentials (same as GraceChords)
# Find these in your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Required: Cloudflare R2 public bucket base URL
# Stem files are resolved as: {VITE_R2_PUBLIC_URL}/tracks/{stem_slug}/{stem_id}.wav
# Example: https://assets.gracechords.com
VITE_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev
