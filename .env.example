# GraceTracks environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Frontend (Vite build-time, VITE_ prefix required) ──────────────────────

# Required: Supabase project credentials (same as GraceChords)
# Find these in your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Required: Cloudflare R2 public bucket base URL
# Stem files are resolved as: {VITE_R2_PUBLIC_URL}/tracks/{stem_slug}/{stem_id}.wav
# Example: https://assets.gracechords.com
VITE_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# ── Cloudflare Pages Function secrets (NO VITE_ prefix) ────────────────────
# Set these in Cloudflare Pages → Settings → Environment Variables (Production
# and Preview). They are available to Pages Functions at runtime but are NOT
# injected into the frontend bundle.

# Supabase — used by the presign function to verify user JWTs
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Cloudflare R2 API token credentials
# Create at: Cloudflare dashboard → R2 → Manage R2 API tokens
# Required permissions: Object Read & Write on the stems bucket
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET_NAME=gracetracks-stems
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
